{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@nexuspos/shared": ["packages/shared/src/index.ts"],
      "@nexuspos/shared/*": ["packages/shared/src/*"],
      "@nexuspos/database": ["packages/database/src/index.ts"]
    }
  },
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/main" },
    { "path": "./packages/renderer" }
  ],
  "exclude": ["node_modules", "**/dist/**", "**/node_modules/**"]
}
